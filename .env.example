# Blog source: GitHub (default). Posts are read from the contents repo at runtime.
# Do not set REACT_APP_BLOG_SOURCE=local unless you use portfolio/public/blog/.
#
# REACT_APP_BLOG_REPO_OWNER=vatsal259
# REACT_APP_BLOG_REPO_NAME=contents
# REACT_APP_BLOG_FOLDER=blog
# REACT_APP_BLOG_BRANCH=main
# REACT_APP_RESUME_FILE=Resume_Vatsal_Verma.pdf
#
# Optional: raises GitHub API rate limit when listing posts (keep in .env.local, never commit).
# REACT_APP_GITHUB_TOKEN=
